{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2021", "DOM"],

    "jsx": "react-native",

    "strict": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "types": ["react", "react-native"],

    "baseUrl": "."
  },
  "include": [
    "src",
    "App.tsx",
    "index.js"
  ]
}